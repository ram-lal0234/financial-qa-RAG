# LLM Provider
LLM_PROVIDER=openai

# Required
OPENAI_API_KEY=your_key_here

# LLM settings
LLM_MODEL=gpt-5-nano            # Model for RAG generation (gpt-4o-mini, gpt-5-nano, etc.)
GUARDRAIL_MODEL=gpt-5-nano      # Model for intent classification and query rewriting (cheaper model recommended)
MAX_TOKENS=2048                 # Max response tokens
TEMPERATURE=0.0                 # Lower = more factual (omitted for o-series/gpt-4.1+/gpt-5+ models)

# RAG settings
TOP_K=5                         # Number of chunks to retrieve per query
SIMILARITY_THRESHOLD=0.44       # Cosine distance cutoff (lower = stricter match)

# ChromaDB
CHROMA_DIR=./data/chroma        # Where vectors are stored on disk
CHROMA_COLLECTION=earnings_transcripts
